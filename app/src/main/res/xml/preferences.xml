<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <com.puntogris.posture.preferences.CustomSwitchPref
        android:defaultValue="true"
        android:icon="@drawable/ic_notifications_24px"
        android:key="pref_show_notifications"
        android:title="@string/notifications"
        android:summaryOff="@string/notifications_summary_off"
        android:summaryOn="@string/notifications_summary_on"/>

    <com.puntogris.posture.preferences.CustomPref
        android:icon="@drawable/ic_baseline_alarm_24"
        android:key="time_interval_for_notifications"
        android:title="@string/time_interval_alarm" />

    <com.puntogris.posture.preferences.CustomPref
        android:key="alarm_days_notification"
        android:icon="@drawable/ic_outline_calendar_today_24"
        android:title="Dias habilitados para las notificaciones"
        />

    <com.puntogris.posture.preferences.CustomPref
        android:icon="@drawable/ic_baseline_alarm_on_24"
        android:key="start_notification_time"
        android:title="@string/start_alarm_time"/>

    <com.puntogris.posture.preferences.CustomPref
        android:icon="@drawable/ic_baseline_alarm_off_24"
        android:key="end_notification_time"
        android:title="@string/end_alarm_time"/>

    <com.puntogris.posture.preferences.CustomPref
        android:key="bug_report"
        android:icon="@drawable/ic_outline_report_24"
        android:title="@string/bug_report_title_pref"
        android:summary="@string/bug_report_summary_pref"/>


    <com.puntogris.posture.preferences.CustomPref
        android:title="@string/about"
        app:defaultValue="false"
        android:key="panda_animation"
        android:icon="@drawable/ic_info_24px"
        android:summary="@string/app_version"/>

</PreferenceScreen>